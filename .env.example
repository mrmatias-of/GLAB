# G-LAB Admin Panel - Environment Variables
# Copy this file to .env.local and fill in your values

# ============================================================================
# DATABASE - Neon PostgreSQL
# ============================================================================
DATABASE_URL=postgresql://user:password@host/database
DATABASE_URL_UNPOOLED=postgresql://user:password@host/database

# ============================================================================
# AUTHENTICATION - Better Auth
# ============================================================================
# Generate this with: openssl rand -base64 32
BETTER_AUTH_SECRET=your-secret-key-here-min-32-characters

# ============================================================================
# APPLICATION
# ============================================================================
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================================================
# SECURITY SETTINGS
# ============================================================================
# Login attempts before lockout (recommended: 5)
AUTH_MAX_LOGIN_ATTEMPTS=5

# Lockout duration in minutes (recommended: 15)
AUTH_LOCKOUT_DURATION=15

# Session timeout in minutes of inactivity (recommended: 30)
AUTH_SESSION_TIMEOUT=30

# Maximum session age in hours (recommended: 24)
AUTH_MAX_SESSION_AGE=24

# ============================================================================
# LOGGING & MONITORING
# ============================================================================
# Set to 'true' to enable detailed security logging
DEBUG_SECURITY=false

# Sentry DSN for error tracking (optional)
SENTRY_DSN=

# ============================================================================
# ADMIN USER CREDENTIALS (CHANGE THESE!)
# ============================================================================
# Default admin email (used by create-admin-user.mjs script)
ADMIN_EMAIL=admin@glabcursos.com

# Default admin password (used by create-admin-user.mjs script)
# IMPORTANT: Change this and run the script to create a secure password!
ADMIN_PASSWORD=Admin@12345

# ============================================================================
# PRODUCTION ONLY
# ============================================================================
# In production, ensure:
# - NODE_ENV=production
# - DATABASE_URL uses SSL connections
# - BETTER_AUTH_SECRET is a strong random value (32+ chars)
# - All passwords are changed from defaults
# - HTTPS is enforced
# - Secure cookies are enabled
# - Logging is sent to a centralized service

# ============================================================================
# SECURITY CHECKLIST
# ============================================================================
# ✓ Database URL is HTTPS/SSL
# ✓ BETTER_AUTH_SECRET is random and 32+ characters
# ✓ Admin password is changed from default
# ✓ .env file is in .gitignore
# ✓ NODE_ENV is 'production' in Vercel
# ✓ All secrets are stored in Vercel environment variables (not .env files)
# ✓ Rate limiting is configured
# ✓ Session timeout is set appropriately
