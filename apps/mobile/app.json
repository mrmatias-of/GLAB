{
  "expo": {
    "name": "G•LAB Mobile",
    "slug": "glab-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "glab",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTabletMode": true,
      "bundleIdentifier": "com.glabcursos.mobile"
    },
    "android": {
      "package": "com.glabcursos.mobile",
      "versionCode": 1
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow G•LAB to access your location"
        }
      ]
    ]
  }
}
